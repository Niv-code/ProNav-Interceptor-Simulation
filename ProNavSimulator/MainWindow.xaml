<Window x:Class="ProNavSimulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ProNavSimulator"
        Title="Proportional Navigation Radar" Height="650" Width="1000" Background="#0A0A0A" WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#1A1A24" BorderBrush="#333" BorderThickness="0,0,1,0" Padding="15">
            <StackPanel>
                <TextBlock Text="INTERCEPTOR COMMAND" Foreground="#00FF66" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                <TextBlock Text="{Binding Status}" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding DistanceText}" Foreground="#00FF66" FontSize="14" Margin="0,0,0,25" FontFamily="Consolas"/>

                <TextBlock Text="Nav Constant (N):" Foreground="#AAA" FontSize="12"/>
                <TextBlock Text="{Binding NavigationConstant, StringFormat={}{0:F1}}" Foreground="White" FontWeight="Bold"/>
                <Slider Minimum="1" Maximum="10" Value="{Binding NavigationConstant}" Margin="0,5,0,20" TickFrequency="0.5" IsSnapToTickEnabled="True"/>

                <TextBlock Text="Target Evasion (G):" Foreground="#AAA" FontSize="12"/>
                <TextBlock Text="{Binding TargetManeuverIntensity, StringFormat={}{0:F1}}" Foreground="White" FontWeight="Bold"/>
                <Slider Minimum="0" Maximum="15" Value="{Binding TargetManeuverIntensity}" Margin="0,5,0,30"/>

                <Button Content="LAUNCH INTERCEPTOR" Command="{Binding ResetCommand}" Background="#CC0000" Foreground="White" FontWeight="Bold" Height="45" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <Canvas Grid.Column="1" ClipToBounds="True">
            <Path Stroke="#112211" StrokeThickness="1" Data="M 0,100 L 1000,100 M 0,200 L 1000,200 M 0,300 L 1000,300 M 0,400 L 1000,400 M 0,500 L 1000,500 M 0,600 L 1000,600" />
            <Path Stroke="#112211" StrokeThickness="1" Data="M 100,0 L 100,600 M 200,0 L 200,600 M 300,0 L 300,600 M 400,0 L 400,600 M 500,0 L 500,600 M 600,0 L 600,600 M 700,0 L 700,600 M 800,0 L 800,600" />

            <Path Fill="#FF003C" Canvas.Left="{Binding TargetX}" Canvas.Top="{Binding TargetY}" Data="M -10,-10 L 10,0 L -10,10 Z">
                <Path.Effect>
                    <DropShadowEffect Color="#FF003C" BlurRadius="15" ShadowDepth="0"/>
                </Path.Effect>
            </Path>

            <Path Fill="#00FF66" Canvas.Left="{Binding MissileX}" Canvas.Top="{Binding MissileY}" Data="M -15,-5 L 15,0 L -15,5 Z">
                <Path.RenderTransform>
                    <RotateTransform Angle="{Binding MissileHeadingDegrees}" CenterX="0" CenterY="0"/>
                </Path.RenderTransform>
                <Path.Effect>
                    <DropShadowEffect Color="#00FF66" BlurRadius="15" ShadowDepth="0"/>
                </Path.Effect>
            </Path>
        </Canvas>
    </Grid>
</Window>